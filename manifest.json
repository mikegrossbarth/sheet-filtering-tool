{
  "manifest_version": 3,
  "name": "Sheet Filtering Tool",
  "description": "Reviews open Google Sheets against saved custom filtering rules.",
  "version": "0.1.2",
  "icons": {
    "16": "assets/store/icon-16.png",
    "32": "assets/store/icon-32.png",
    "48": "assets/store/icon-48.png",
    "128": "assets/store/icon-128.png"
  },
  "permissions": ["activeTab", "identity", "scripting", "storage", "tabs"],
  "host_permissions": [
    "https://docs.google.com/*",
    "https://keep.google.com/*",
    "https://accounts.google.com/*",
    "https://*.googleusercontent.com/*",
    "https://sheets.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "414248778969-rndm1rj8ts7784tpuecdjn5tv9cin24i.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/spreadsheets"]
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Sheet Filtering Tool",
    "default_icon": {
      "16": "assets/store/icon-16.png",
      "32": "assets/store/icon-32.png",
      "48": "assets/store/icon-48.png",
      "128": "assets/store/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/spreadsheets/*"],
      "js": ["src/player-sport-data.js", "src/rules-engine.js", "src/sheets-content.js"],
      "css": ["src/sheets-content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://keep.google.com/*"],
      "js": ["src/keep-content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/popup.html",
        "src/popup.css",
        "src/popup.js",
        "src/default-filters.js",
        "src/player-sport-data.js",
        "src/rules-engine.js"
      ],
      "matches": ["https://docs.google.com/*"]
    }
  ]
}
